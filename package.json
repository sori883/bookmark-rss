{
  "name": "cf-template",
  "private": true,
  "engines": {
    "node": "^24.15.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @acme/auth generate",
    "cli": "dotenv -e .env -- node apps/cli/src/index.ts",
    "db:generate": "turbo run generate -F @acme/db",
    "db:push": "turbo -F @acme/db push",
    "db:migrate": "turbo -F @acme/db migrate",
    "db:migrate:prod": "pnpm -F @acme/db migrate:prod",
    "db:apply-extras": "turbo -F @acme/db apply-extras",
    "db:apply-extras:prod": "pnpm -F @acme/db apply-extras:prod",
    "db:studio": "turbo -F @acme/db studio",
    "rec:clear": "sqlite3 .datastore/db.sqlite 'DELETE FROM recommendation_item; DELETE FROM recommendation;'",
    "rec:regen": "pnpm rec:clear && pnpm -F @acme/worker-ai trigger",
    "dev": "turbo watch dev --continue",
    "deploy:prod": "pnpm -F @acme/worker-jobs deploy:prod && pnpm -F @acme/worker-ai deploy:prod && pnpm -F @acme/web cf-deploy:prod",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "test": "turbo run test --continue",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
