DATABASE_URL='http://127.0.0.1:8080'
DATABASE_AUTH_TOKEN='local'

BETTER_AUTH_URL='http://localhost:3000'
BETTER_AUTH_SECRET=''
BETTER_TRUSTED_URL='http://localhost:3000'
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''

BOOKMARK_API_URL='http://localhost:3000'

VITE_API_BASE_URL='http://localhost:3000'

# 32-byte hex (use: openssl rand -hex 32). Encrypts Discord webhook URLs at rest.
ENCRYPTION_MASTER_KEY=''

# --- AI recommendation (apps/worker-ai) ---
# The worker calls env.AI.run("google/gemini-3.1-flash-lite", ...) via
# the AI binding. Cloudflare Unified Billing pays for the upstream Gemini
# call, so there is no GCP / Vertex AI / SA JSON to manage.
# Only the AI Gateway name (created in the Cloudflare dashboard) is
# needed so the call is routed and observed through that gateway.
CF_AI_GATEWAY_ID='bookmark-rss-ai'

# Used in the Discord embed link
WEB_BASE_URL='http://localhost:3000'