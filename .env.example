DATABASE_URL='http://127.0.0.1:8080'
DATABASE_AUTH_TOKEN='local'

BETTER_AUTH_URL='http://localhost:3000'
BETTER_AUTH_SECRET=''
BETTER_TRUSTED_URL='http://localhost:3000'
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''

BOOKMARK_API_URL='http://localhost:3000'

VITE_API_BASE_URL='http://localhost:3000'

# 32-byte hex (use: openssl rand -hex 32). Encrypts Discord webhook URLs at rest.
ENCRYPTION_MASTER_KEY=''

# --- AI recommendation (apps/worker-ai) ---
# The worker calls Vertex AI Gemini via Cloudflare AI Gateway in BYOK
# mode. Service Account JSON is registered in the Cloudflare dashboard
# (AI Gateway -> Provider Keys -> Google Vertex AI), so the worker
# itself never holds the SA private key. Vertex AI usage is billed to
# the GCP project linked to the SA.
GCP_PROJECT_ID=''
VERTEX_AI_LOCATION='asia-northeast1'
VERTEX_AI_MODEL='gemini-2.5-flash-lite'

CF_ACCOUNT_ID=''
CF_AI_GATEWAY_ID='bookmark-rss-ai'
# Only required if you turn on "Authenticated Gateway" in the dashboard.
CF_AI_GATEWAY_TOKEN=''

# Used in the Discord embed link
WEB_BASE_URL='http://localhost:3000'