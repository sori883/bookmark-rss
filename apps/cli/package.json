{
  "name": "@acme/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "bookmark": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "start": "node src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/auth-client": "workspace:*",
    "@clack/prompts": "^0.11.0",
    "citty": "^0.1.6",
    "hono": "^4.12.18",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:^",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "^17.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "^0.18.0",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  },
  "prettier": "@acme/prettier-config"
}
