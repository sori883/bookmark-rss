{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bookmark-rss-ai",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.ts",
  // Disable the public *.workers.dev URL — Cron Trigger is the only invoker
  "workers_dev": false,
  "triggers": {
    "crons": ["0 * * * *"],
  },
  "ai": {
    "binding": "AI",
  },
}
