{
  "name": "@acme/worker-jobs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env vite dev --port 8788",
    "trigger": "curl -sfS -X POST 'http://localhost:8788/trigger' -w '[trigger] HTTP %{http_code}\\n'",
    "build": "pnpm with-env vite build",
    "deploy:prod": "pnpm with-env-prod vite build && pnpm with-env-prod wrangler deploy --secrets-file ../../.env.prod",
    "cf-typegen": "pnpm with-env wrangler types --env-interface CloudflareBindings",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "with-env": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true dotenv -e ../../.env --",
    "with-env-prod": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true dotenv -e ../../.env.prod --"
  },
  "dependencies": {
    "@acme/db": "workspace:*",
    "@acme/jobs": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "catalog:",
    "hono": "^4.12.18",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:^",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.13",
    "wrangler": "^4.92.0"
  },
  "prettier": "@acme/prettier-config"
}
